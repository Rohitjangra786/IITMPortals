# ---- Local development (SQLite file DB) ----
# Used by the Prisma CLI (db push / generate / seed) and, when no TURSO_* vars
# are set, by the app at runtime.
DATABASE_URL="file:./dev.db"

# Session signing secret (set a strong random value in production).
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- Production (Vercel + Turso / libSQL) ----
# When TURSO_DATABASE_URL is set, the app connects to Turso via the libSQL
# driver adapter instead of the local file. Create a DB at https://turso.tech
# then set these in the Vercel project settings (do NOT commit real values):
#
#   turso db create iitm-portals
#   turso db show iitm-portals        # -> libsql://... URL
#   turso db tokens create iitm-portals
#
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"
