// JAC Inspection Portal — database schema
// SQLite via Prisma. The rich inspection form is stored as a JSON string in
// `Inspection.data`; computed summary fields are persisted as real columns so
// the dashboard can list and filter without parsing every blob.

generator client {
  provider      = "prisma-client-js"
  // native = local dev; rhel-openssl-3.0.x = Vercel serverless runtime. The
  // libSQL driver adapter (Turso) is enabled in code; no preview flag needed.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  // Static placeholder: used by the Prisma CLI and the local file DB. In
  // production the libSQL driver adapter (Turso) supplies the real connection,
  // so this must NOT depend on a runtime env var (DATABASE_URL is unset on
  // Vercel, which would otherwise crash the client when the adapter is used).
  url      = "file:./dev.db"
}

/// A committee member / user of the portal.
model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  // admin | chairperson | expert | convenor | member
  role         String       @default("member")
  createdAt    DateTime     @default(now())
  inspections  Inspection[]
}

/// An institute that is being assessed.
model Institute {
  id          String       @id @default(cuid())
  name        String
  address     String       @default("")
  district    String       @default("")
  telephone   String       @default("")
  website     String       @default("")
  email       String       @default("")
  societyName String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  inspections Inspection[]
}

/// One JAC assessment report for an institute in a given session.
model Inspection {
  id          String    @id @default(cuid())
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  instituteId String
  session     String    @default("2026-27")
  dateOfVisit String    @default("")
  // draft | submitted
  status      String    @default("draft")
  // Full form payload serialised as JSON (see lib/types.ts -> InspectionData).
  data        String    @default("{}")

  // ---- Persisted computed summary (kept in sync on every save) ----
  partIIMax      Int   @default(0)
  partIIAwarded  Int   @default(0)
  partIIPercent  Float @default(0)
  partIIIMax     Int   @default(200)
  partIIIAwarded Int   @default(0)
  partIIIPercent Float @default(0)
  // A | B | C | D | "" (overall, the lower of Part II and Part III)
  category String @default("")

  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([instituteId])
}
